#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=../lib/draccus-env.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../lib/draccus-env.sh"
DRACCUS_RUN="${DRACCUS_RUN:-$DRACCUS_BUNDLE/bin/draccus-run}"

echo "[outer] bwrap"
command -v bwrap
bwrap --version || true

echo ""
echo "[outer] gpu devices"
ls -l /dev/nvidia* 2>/dev/null || true

# Report Spack commit if a checkout exists (supports SPACK_REF pinning workflow)
if [[ -d "$DRACCUS_BUNDLE/state/spack/.git" ]]; then
  echo ""
  echo "[outer] Spack revision"
  (cd "$DRACCUS_BUNDLE/state/spack" && git rev-parse --short HEAD) || true
fi

echo ""
echo "[inner] namespace/rootfs/path contract"
if ! "$DRACCUS_RUN" bash -lc '
  set -euo pipefail
  echo "id: $(id)"
  echo "kernel: $(uname -a)"
  echo "os-release:"
  cat /etc/os-release || true
  echo "DRACCUS_PREFIX=$DRACCUS_PREFIX"
  echo "SPACK_ROOT=$SPACK_ROOT"
  echo "CUDA_HOME=$CUDA_HOME"
  test "$DRACCUS_PREFIX" = /opt/draccus
  test "$SPACK_ROOT" = /opt/draccus/spack
  test -d /opt/draccus
  test -d /work/src
'; then
  echo ""
  echo "ERROR: Failed to enter bwrap namespace."
  echo "Most common cause: user namespaces disabled on this host."
  echo "Try one of:"
  echo "  sudo sysctl kernel.unprivileged_userns_clone=1"
  echo "  sudo sysctl kernel.apparmor_restrict_unprivileged_userns=0   # Debian/Ubuntu"
  echo "Then re-run: $0"
  exit 1
fi
