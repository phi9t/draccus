#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=../lib/draccus-env.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../lib/draccus-env.sh"
DRACCUS_ROOTFS="${DRACCUS_ROOTFS:-$DRACCUS_BUNDLE/rootfs}"
DRACCUS_STATE="${DRACCUS_STATE:-$DRACCUS_BUNDLE/state}"
DRACCUS_CACHE="${DRACCUS_CACHE:-$DRACCUS_BUNDLE/cache}"
DRACCUS_BUILD="${DRACCUS_BUILD:-$DRACCUS_BUNDLE/build}"
DRACCUS_WORKSPACE="${DRACCUS_WORKSPACE:-$PWD}"

# shellcheck source=../lib/draccus-bwrap-env.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../lib/draccus-bwrap-env.sh"

cuda_ld_extra=""
if [[ -n "${DRACCUS_BWRAP_CUDA_LD_EXTRA:-}" ]]; then
  cuda_ld_extra=":${DRACCUS_BWRAP_CUDA_LD_EXTRA%:}"
fi

# UV layering enforcement (UV_EXTRA_OVERRIDES)
uv_overrides_args=()
if [[ -f "$DRACCUS_BUNDLE/scripts/uv_overrides.txt" ]]; then
  uv_overrides_args+=(--ro-bind "$DRACCUS_BUNDLE/scripts/uv_overrides.txt" /opt/draccus/uv_overrides.txt)
  uv_overrides_args+=(--setenv UV_EXTRA_OVERRIDES /opt/draccus/uv_overrides.txt)
fi

BWRAP="${BWRAP:-$(command -v bwrap || true)}"

if [[ -z "$BWRAP" || ! -x "$BWRAP" ]]; then
  echo "draccus-run: bubblewrap (bwrap) not found; install bubblewrap" >&2
  exit 127
fi

if [[ ! -e "$DRACCUS_ROOTFS/bin/sh" ]]; then
  echo "draccus-run: rootfs incomplete: missing $DRACCUS_ROOTFS/bin/sh (see EDD §11.2)" >&2
  exit 1
fi

mkdir -p \
  "$DRACCUS_STATE/spack" \
  "$DRACCUS_STATE/view" \
  "$DRACCUS_STATE/var-intel" \
  "$DRACCUS_CACHE/spack" \
  "$DRACCUS_CACHE/uv" \
  "$DRACCUS_CACHE/huggingface" \
  "$DRACCUS_BUILD/stage"

# shellcheck source=../lib/draccus-view-dir.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../lib/draccus-view-dir.sh"
draccus_ensure_state_view_slot base-sys
draccus_ensure_state_view_slot base-ml

mkdir -p "$DRACCUS_BUNDLE/envs/base-sys" "$DRACCUS_BUNDLE/envs/base-ml"

gpu_args=()
driver_args=()

# shellcheck source=../lib/draccus-nvidia-mounts.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../lib/draccus-nvidia-mounts.sh"
draccus_append_nvidia_mounts gpu_args driver_args

net_args=()
if [[ "${DRACCUS_OFFLINE:-0}" == "1" ]]; then
  net_args+=(--unshare-net)
fi

# Host /etc overlays must use --ro-bind-data: plain --ro-bind-try breaks when / is ro-bind from rootfs.
net_overlay_args=()
if [[ "${DRACCUS_OFFLINE:-0}" != "1" ]]; then
  if [[ -r /etc/resolv.conf ]]; then
    exec {DRACCUS_FD_RESOLV}</etc/resolv.conf
    net_overlay_args+=(--ro-bind-data "$DRACCUS_FD_RESOLV" /etc/resolv.conf)
  fi
  if [[ -r /etc/hosts ]]; then
    exec {DRACCUS_FD_HOSTS}</etc/hosts
    net_overlay_args+=(--ro-bind-data "$DRACCUS_FD_HOSTS" /etc/hosts)
  fi
fi

# Host-only: default PATH lists base-ml before base-sys (Torch/JAX foundation `python`).
# Pip/pip3 from Spack's py-pip are shadowed by bundle shims mounted at /opt/draccus/shims (prepended).
# For infra/debug (base-sys ahead of base-ml), set DRACCUS_PREFER_SYS_PATH=1 on the host or use
# bin/draccus-debug-shell.
draccus_path_views="/opt/draccus/shims:/opt/draccus/view/base-ml/bin:/opt/draccus/view/base-sys/bin"
if [[ "${DRACCUS_PREFER_SYS_PATH:-0}" =~ ^(1|true|yes)$ ]]; then
  draccus_path_views="/opt/draccus/shims:/opt/draccus/view/base-sys/bin:/opt/draccus/view/base-ml/bin"
fi

# Writable /opt (tmpfs): Intel oneAPI prerequisites probe writability under /opt.
# Writable /var (tmpfs) + state-backed /var/intel: oneAPI packagemanager uses /var/intel/installercache; the NVIDIA
# rootfs image makes the real /var subtree read-only inside the ro-bind.
exec "$BWRAP" \
  --die-with-parent \
  --unshare-user \
  --uid 0 \
  --gid 0 \
  --unshare-ipc \
  --unshare-pid \
  --unshare-uts \
  "${net_args[@]}" \
  --ro-bind "$DRACCUS_ROOTFS" / \
  --tmpfs /opt \
  --ro-bind-try "$DRACCUS_ROOTFS/opt/nvidia" /opt/nvidia \
  --tmpfs /var \
  --bind "$DRACCUS_STATE/var-intel" /var/intel \
  --proc /proc \
  --dev /dev \
  --ro-bind-try /sys /sys \
  --tmpfs /tmp \
  --tmpfs /run \
  "${gpu_args[@]}" \
  --ro-bind "$DRACCUS_BUNDLE/host-bin" /opt/draccus/host-bin \
  "${driver_args[@]}" \
  "${net_overlay_args[@]}" \
  --ro-bind "$DRACCUS_BUNDLE/shims" /opt/draccus/shims \
  --ro-bind "$DRACCUS_BUNDLE/envs" /opt/draccus/envs \
  --ro-bind "$DRACCUS_STATE/spack" /opt/draccus/spack \
  --ro-bind "$DRACCUS_STATE/view" /opt/draccus/view \
  --bind "$DRACCUS_CACHE" /opt/draccus/cache \
  --bind "$DRACCUS_BUILD" /opt/draccus/build \
  --bind "$DRACCUS_WORKSPACE" /workspace \
  "${uv_overrides_args[@]}" \
  --setenv DRACCUS_PREFIX /opt/draccus \
  --setenv SPACK_ROOT /opt/draccus/spack \
  --setenv SPACK_SYS_VIEW /opt/draccus/view/base-sys \
  --setenv SPACK_ML_VIEW /opt/draccus/view/base-ml \
  --setenv DRACCUS_SYS_VIEW /opt/draccus/view/base-sys \
  --setenv DRACCUS_ML_VIEW /opt/draccus/view/base-ml \
  --setenv SPACK_USER_CACHE_PATH /opt/draccus/cache/spack \
  --setenv UV_CACHE_DIR /opt/draccus/cache/uv \
  --setenv UV_LINK_MODE copy \
  --setenv HF_HOME /opt/draccus/cache/huggingface \
  --setenv CUDA_HOME "$DRACCUS_RESOLVED_CUDA_HOME" \
  --setenv CUDA_ROOT "$DRACCUS_RESOLVED_CUDA_ROOT" \
  --setenv TORCH_CUDA_ARCH_LIST "10.0" \
  --setenv PYTHONNOUSERSITE "1" \
  --setenv HOME /workspace \
  --setenv DRACCUS_WORKSPACE /workspace \
  --setenv PATH "${draccus_path_views}:/opt/draccus/host-bin:${DRACCUS_BWRAP_CUDA_BIN_PREFIX:-}/usr/local/nvidia/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin" \
  --setenv LD_LIBRARY_PATH "/usr/local/nvidia/lib:/usr/local/nvidia/lib64:/usr/local/cuda/lib64:/usr/local/cuda/lib${cuda_ld_extra}:/opt/draccus/view/base-ml/lib:/opt/draccus/view/base-ml/lib64" \
  --chdir /workspace \
  "$@"
